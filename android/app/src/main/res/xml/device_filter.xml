<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- USB Printer Class (class 7) - catches ALL standard USB printers -->
    <usb-device class="7" />

    <!-- Xprinter (XP-58, XP-80, etc.) -->
    <usb-device vendor-id="1155" />  <!-- 0x0483 STMicroelectronics -->
    <usb-device vendor-id="8137" />  <!-- 0x1FC9 NXP -->

    <!-- Epson TM series -->
    <usb-device vendor-id="1208" />  <!-- 0x04B8 -->

    <!-- TVS (RP-3160, etc.) -->
    <usb-device vendor-id="3540" />  <!-- 0x0DD4 -->

    <!-- Generic POS-58/80 printers -->
    <usb-device vendor-id="1046" />  <!-- 0x0416 Winbond -->
    <usb-device vendor-id="1171" />  <!-- 0x0493 -->

    <!-- USB-Serial bridge chips (CH340, PL2303, FTDI) -->
    <usb-device vendor-id="6790" />  <!-- 0x1A86 QinHeng CH340 -->
    <usb-device vendor-id="1659" />  <!-- 0x067B Prolific PL2303 -->
    <usb-device vendor-id="1027" />  <!-- 0x0403 FTDI -->

    <!-- Star Micronics -->
    <usb-device vendor-id="2816" />  <!-- 0x0B00 -->

    <!-- Citizen -->
    <usb-device vendor-id="1208" />  <!-- 0x04B8 shared with Epson -->

    <!-- Bixolon -->
    <usb-device vendor-id="4418" />  <!-- 0x1142 -->

    <!-- Custom/Dmax -->
    <usb-device vendor-id="8401" />  <!-- 0x20D1 -->

    <!-- WCH CH34x -->
    <usb-device vendor-id="17224" /> <!-- 0x4348 -->

    <!-- Rongta -->
    <usb-device vendor-id="1046" />  <!-- 0x0416 -->

    <!-- HOIN/GOOJPRT -->
    <usb-device vendor-id="1155" />  <!-- 0x0483 shared -->
</resources>
